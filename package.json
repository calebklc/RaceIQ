{
  "name": "raceiq",
  "version": "0.2.0",
  "type": "module",
  "workspaces": [
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun --watch run server/index.ts",
    "dev:client": "cd client && portless raceiq bun run dev",
    "build": "mkdir -p dist && rm -rf dist/* && cd client && bun vite build && cd .. && bun scripts/copy-shared-data.ts && cp -r client/dist dist/public && NODE_ENV=production bun build --compile server/index.ts --outfile dist/raceiq",
    "start": "NODE_ENV=production ./dist/raceiq",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "test": "bun test",
    "extract:tracks": "bun scripts/extract-fm2023-tracks.ts && bun scripts/extract-f1-tracks.ts",
    "extract:tracks:forza": "bun scripts/extract-fm2023-tracks.ts",
    "extract:tracks:f1": "bun scripts/extract-f1-25-tracks.ts",
    "laps:export": "bun scripts/export-laps.ts",
    "laps:import": "bun scripts/import-laps.ts",
    "lighthouse": "lighthouse http://raceiq.localhost:1355/ --only-categories=accessibility,performance,best-practices --chrome-flags=\"--headless=new --no-sandbox --disable-gpu\" --output=html --output-path=./lighthouse-report.html && echo 'Report: lighthouse-report.html'"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "drizzle-orm": "^0.45.2",
    "fflate": "^0.8.2",
    "fzstd": "^0.1.1",
    "hono": "^4.12.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.2.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "lighthouse": "^13.0.3",
    "portless": "^0.9.4"
  }
}
