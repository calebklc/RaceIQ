    "damping": { "frontRebound": 8.5, "rearRebound": 8.0, "frontBump": 4.5, "rearBump": 4.0 },
    "aero": { "frontDownforce": 120, "rearDownforce": 140, "unit": "kgf" },
    "differential": { "rearAccel": 55, "rearDecel": 30 },
