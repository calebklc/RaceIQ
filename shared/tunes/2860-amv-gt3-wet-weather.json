    "alignment": {
      "frontCamber": -0.8,
      "rearCamber": -0.5,
      "frontToe": 0.0,
      "rearToe": 0.0,
      "frontCaster": 5.5
    },
    "antiRollBars": { "front": 16.0, "rear": 14.0 },
